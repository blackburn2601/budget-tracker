# Copy this file to ".env.local" and fill in your Supabase project values.
# The app works WITHOUT these (localStorage only); they enable cloud sync.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-anon-public-key
# Optional: identifier for your snapshot row (default: "default")
VITE_SUPABASE_ROW_KEY=default
